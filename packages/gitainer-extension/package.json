{
    "name": "gitainer-extension",
    "displayName": "Gitainer",
    "description": "Preview Gitainer stack hydration and environment variables",
    "version": "0.0.3",
    "publisher": "gitainer",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/martindmtrv/gitainer.git"
    },
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:gitainer.previewHydration",
        "onCommand:gitainer.previewEnv",
        "onLanguage:yaml",
        "onLanguage:dockercompose",
        "onLanguage:docker-compose"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "gitainer.previewHydration",
                "title": "Gitainer: Preview Hydration"
            },
            {
                "command": "gitainer.previewEnv",
                "title": "Gitainer: Preview Env Variables"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "bun run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "bun run compile && bun run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js",
        "package": "vsce package --no-dependencies",
        "publish": "vsce publish --no-dependencies"
    },
    "devDependencies": {
        "@types/vscode": "^1.110.0",
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^10.2.0",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "typescript": "^6.0.2",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1"
    }
}